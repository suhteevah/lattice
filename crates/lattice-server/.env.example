# Lattice server environment variables.
# Copy to .env (git-ignored) for local development.

# Listener
LATTICE__SERVER__BIND_ADDR=0.0.0.0:8443

# Environment label: development | staging | production
LATTICE__ENVIRONMENT=development

# Database (Postgres)
LATTICE__DATABASE_URL=postgres://lattice:lattice@localhost:5432/lattice

# Federation key path
LATTICE__FEDERATION_KEY_PATH=./federation.key

# Tracing — set this generously during dev
RUST_LOG=lattice=trace,tower_http=debug,sqlx=warn
RUST_BACKTRACE=1
