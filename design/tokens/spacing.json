{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Lattice spacing and layout tokens. 4px base grid.",
  "$version": "0.1.0",

  "space": {
    "0":  { "$value": "0px",   "$type": "dimension" },
    "1":  { "$value": "4px",   "$type": "dimension" },
    "2":  { "$value": "8px",   "$type": "dimension" },
    "3":  { "$value": "12px",  "$type": "dimension" },
    "4":  { "$value": "16px",  "$type": "dimension" },
    "5":  { "$value": "20px",  "$type": "dimension" },
    "6":  { "$value": "24px",  "$type": "dimension" },
    "8":  { "$value": "32px",  "$type": "dimension" },
    "10": { "$value": "40px",  "$type": "dimension" },
    "12": { "$value": "48px",  "$type": "dimension" },
    "16": { "$value": "64px",  "$type": "dimension" },
    "20": { "$value": "80px",  "$type": "dimension" },
    "24": { "$value": "96px",  "$type": "dimension" }
  },

  "radius": {
    "none":  { "$value": "0px",    "$type": "dimension" },
    "sm":    { "$value": "4px",    "$type": "dimension" },
    "md":    { "$value": "8px",    "$type": "dimension" },
    "lg":    { "$value": "12px",   "$type": "dimension" },
    "xl":    { "$value": "16px",   "$type": "dimension" },
    "pill":  { "$value": "9999px", "$type": "dimension" }
  },

  "borderWidth": {
    "thin":   { "$value": "0.5px", "$type": "dimension" },
    "normal": { "$value": "1px",   "$type": "dimension" },
    "thick":  { "$value": "2px",   "$type": "dimension" }
  },

  "layout": {
    "sidebar-width":        { "$value": "240px", "$type": "dimension" },
    "channel-list-width":   { "$value": "200px", "$type": "dimension" },
    "member-list-width":    { "$value": "220px", "$type": "dimension" },
    "message-max-width":    { "$value": "720px", "$type": "dimension" },
    "compose-height":       { "$value": "44px",  "$type": "dimension" },
    "header-height":        { "$value": "48px",  "$type": "dimension" }
  },

  "motion": {
    "duration": {
      "instant":    { "$value": "0ms",   "$type": "duration" },
      "fast":       { "$value": "120ms", "$type": "duration" },
      "moderate":   { "$value": "200ms", "$type": "duration" },
      "slow":       { "$value": "320ms", "$type": "duration" }
    },
    "easing": {
      "standard":   { "$value": "cubic-bezier(0.2, 0, 0, 1)",       "$type": "cubicBezier" },
      "entrance":   { "$value": "cubic-bezier(0, 0, 0, 1)",         "$type": "cubicBezier" },
      "exit":       { "$value": "cubic-bezier(0.4, 0, 1, 1)",       "$type": "cubicBezier" }
    }
  }
}
