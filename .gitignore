# Rust
/target/
**/target/
**/*.rs.bk
Cargo.lock.bak

# Cargo registry / credentials cache. The workspace-level
# `.cargo/config.toml` (linker override for Windows) IS tracked —
# only the registry cache subdirs are ignored.
.cargo/registry/
.cargo/credentials*
.cargo/.crates*.toml

# IDE
.vscode/
.idea/
*.iml
.fleet/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Env
.env
.env.local
.env.*.local
!.env.example

# Web (lattice-web is Rust + Leptos via Trunk — no JS toolchain)
apps/lattice-web/dist/
apps/lattice-web/trunk-serve*.log
apps/lattice-web/trunk-serve*.err.log

# Federation keys (NEVER commit)
federation.key
*.pem
*.key
!**/scripts/*.key

# Local databases
*.sqlite
*.sqlite-journal
*.db

# Coverage
/coverage/
*.lcov
*.profraw

# Generated docs
/docs/api/

scratch/

