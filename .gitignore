# Rust
/target/
**/target/
**/*.rs.bk
Cargo.lock.bak

# Cargo registry / credentials cache. The workspace-level
# `.cargo/config.toml` (linker override for Windows) IS tracked —
# only the registry cache subdirs are ignored.
.cargo/registry/
.cargo/credentials*
.cargo/.crates*.toml

# IDE
.vscode/
.idea/
*.iml
.fleet/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Env
.env
.env.local
.env.*.local
!.env.example

# Web (lattice-web is Rust + Leptos via Trunk — no JS toolchain)
apps/lattice-web/dist/
apps/lattice-web/trunk-serve*.log
apps/lattice-web/trunk-serve*.err.log

# Desktop (Tauri 2). `gen/` is regenerated by tauri-build at compile
# time from `capabilities/*.json` + `tauri.conf.json`; checking it in
# guarantees drift the next time `cargo tauri` runs. `source-*.png`
# is the temporary input for `cargo tauri icon` — the generated icon
# set IS tracked so a clean clone can build.
apps/lattice-desktop/src-tauri/gen/
apps/lattice-desktop/src-tauri/icons/source-*.png

# Federation keys (NEVER commit)
federation.key
*.pem
*.key
!**/scripts/*.key

# Local databases
*.sqlite
*.sqlite-journal
*.db

# Coverage
/coverage/
*.lcov
*.profraw

# Generated docs
/docs/api/

scratch/

# Local dev-server run dir (federation key, state snapshot, log)
/.run/


# Added by uploader (secret-leak hardening, 2026-04-18)
.secrets
VOXCLAW.md
*.local
nul
id_rsa
id_ed25519
*-key
.claude/.credentials.json
C:Users*
C:Windows*

# Windows reserved device names (cause git add failures)
nul
con
prn
aux
com1
com2
com3
com4
com5
com6
com7
com8
com9
lpt1
lpt2
lpt3
lpt4
lpt5
lpt6
lpt7
lpt8
lpt9
scratch/.registration-token
